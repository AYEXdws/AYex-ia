OPENAI_API_KEY=YOUR_OPENAI_API_KEY

OPENCLAW_ENABLED=true
OPENCLAW_BASE_URL=http://127.0.0.1:18789
OPENCLAW_API_KEY=YOUR_OPENCLAW_GATEWAY_TOKEN
OPENCLAW_MODE=openai_chat_completions
OPENCLAW_MODEL=openai/gpt-4o-mini
OPENCLAW_FORCE_MODEL=true
OPENCLAW_MAX_OUTPUT_TOKENS=56
OPENCLAW_TIMEOUT_SEC=18
OPENCLAW_CONTEXT_TURNS=2
OPENCLAW_CACHE_TTL_SEC=120
OPENCLAW_CACHE_SIZE=128
OPENCLAW_INSTRUCTIONS="Her zaman Turkce cevap ver. Kisa, net ve dogal yaz. Basit sorularda 2-4 cumle kullan; analiz gereken durumda maddeli ve yapisal yanit ver."
OPENCLAW_PUBLIC_URL=ws://127.0.0.1:18789
OPENCLAW_HOOKS_TOKEN=
OPENCLAW_CRON_WEBHOOK_TOKEN=
OPENCLAW_OTEL_ENABLED=false
OPENCLAW_OTEL_ENDPOINT=
AYEX_WEB_MVP_ONLY=true
AYEX_DATA_DIR=.ayex
AYEX_PROFILE_PATH=.ayex/profile.json
AYEX_CHAT_DIR=.ayex/chats
AYEX_DAILY_REQUEST_LIMIT=350
AYEX_DAILY_INPUT_CHAR_LIMIT=120000

AYEX_AUDIO_ENGINE_DEFAULT=openclaw
AYEX_DEFAULT_VOICE=alloy
AYEX_TTS_MODEL=gpt-4o-mini-tts
AYEX_STT_MODEL=gpt-4o-mini-transcribe

# Direct OpenAI mode (OpenClaw bridge off):
# OPENCLAW_ENABLED=false
