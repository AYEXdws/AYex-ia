OPENAI_API_KEY=YOUR_OPENAI_API_KEY
# AYEX_API_KEY=YOUR_OPENAI_API_KEY   # legacy fallback (OPENAI_API_KEY primary)
ANTHROPIC_API_KEY=

AYEX_USER=ayex
AYEX_PASS=change-me
AYEX_JWT_SECRET=change-me-jwt-secret

AYEX_MODEL=claude-haiku-4.5
AYEX_CHAT_MODEL=claude-haiku-4.5
AYEX_REASONING_MODEL=claude-sonnet-4.6
AYEX_POWER_MODEL=gpt-5
AYEX_FAST_MODEL=gpt-4o-mini

AYEX_MODEL_MAX_OUTPUT_TOKENS=320
AYEX_MODEL_CONTEXT_TURNS=6
AYEX_MODEL_CACHE_TTL_SEC=45
AYEX_MODEL_CACHE_SIZE=128
AYEX_INTEL_PROMPT_MAX_EVENTS=20
AYEX_INTEL_PROMPT_MAX_CHARS=4200
# AYEX_MODEL_INSTRUCTIONS=Sen AYEX'sin...

AYEX_WEB_MVP_ONLY=true
AYEX_DATA_DIR=.ayex
AYEX_PROFILE_PATH=.ayex/profile.json
AYEX_CHAT_DIR=.ayex/chats
AYEX_DAILY_REQUEST_LIMIT=350
AYEX_DAILY_INPUT_CHAR_LIMIT=120000
AYEX_INTEL_INGEST_TOKEN=
AYEX_INTEL_INGEST_RPM=120

AYEX_AUDIO_ENGINE_DEFAULT=openai
AYEX_DEFAULT_VOICE=alloy
AYEX_TTS_MODEL=gpt-4o-mini-tts
AYEX_STT_MODEL=gpt-4o-mini-transcribe
AYEX_OPENAI_TIMEOUT_SEC=45
